{
  "name": "pi-codegraph",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi coding agent extension for CodeGraph CLI integration — semantic code intelligence for faster code exploration",
  "keywords": [
    "pi-package",
    "pi-extension",
    "codegraph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/pi-codegraph"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "biome:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo 'pi loads TypeScript extensions via jiti'",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
